# Copy to .env and fill in.  ->  cp .env.example .env
# .env is gitignored. Never commit real credentials.
#
# IMPORTANT: cluster config lives ONLY in this file. The harness never reads
# CB_* from your shell, so an exported CB_CONNECTION_STRING (e.g. a Capella URL
# in your ~/.zshrc) will NOT leak into the container.

# ─────────────────────────────────────────────────────────────────────────────
# 1. Claude Code auth (REQUIRED — one of the two)
# ─────────────────────────────────────────────────────────────────────────────
# Preferred: a long-lived OAuth token tied to your Claude subscription.
# Generate it once on your host (opens a browser to log into your account):
#     claude setup-token
# then paste the printed token here.
CLAUDE_CODE_OAUTH_TOKEN=

# Fallback: an Anthropic API key (Console / pay-per-token billing).
# Used only if CLAUDE_CODE_OAUTH_TOKEN is empty.
# ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# 2. Skill source
# ─────────────────────────────────────────────────────────────────────────────
# local  = copy skills from this repo's working tree (test un-merged edits)  [default]
# github = install the published plugin from the marketplace
SKILL_INSTALL_MODE=local
SKILLS_MARKETPLACE=Couchbase-Ecosystem/agent-skills

# ─────────────────────────────────────────────────────────────────────────────
# 3. Cluster
# ─────────────────────────────────────────────────────────────────────────────
# Which cluster you hit is chosen by the make TARGET, not by a variable:
#   make sandbox / sandbox-setup            -> local bundled cluster   (see 3a)
#   make sandbox-remote / sandbox-setup-remote -> remote cluster from .env (see 3b)

# 3a. LOCAL cluster (make sandbox / sandbox-setup)
#   The harness fixes the connection string (couchbase://couchbase) and db user
#   (tester). CB_LOCAL_PASSWORD is REQUIRED — choose any value; it only applies to
#   the ephemeral local Docker container and is never sent to an external cluster.
CB_LOCAL_PASSWORD=
# CB_ADMIN_PASSWORD=   # optional — defaults to CB_LOCAL_PASSWORD if not set
# CB_LOCAL_USERNAME=tester
# CB_MCP_READ_ONLY_MODE=true
# CB_IMAGE=couchbase:enterprise-8.0.1

# 3b. REMOTE / Capella cluster (make sandbox-remote / sandbox-setup-remote)
#   Used ONLY by the remote targets. Fill these in:
# CB_CONNECTION_STRING=couchbases://cb.xxxxx.cloud.couchbase.com
# CB_USERNAME=your-db-user
# CB_PASSWORD=your-db-password
# CB_MCP_READ_ONLY_MODE=true

# ─────────────────────────────────────────────────────────────────────────────
# 4. Build pins (optional) — HARNESS_-prefixed so they don't collide with the
#    CLAUDE_CODE_VERSION that Claude Code sets in its own terminals.
# ─────────────────────────────────────────────────────────────────────────────
# HARNESS_CLAUDE_CODE_VERSION=latest
# HARNESS_MCP_SERVER_SPEC=couchbase-mcp-server>=1.0.0,<1.1.0
