{
  "mcpServers": {
    "couchbase": {
      "command": "uvx",
      "args": ["--from", "couchbase-mcp-server>=0.8.0,<0.9.0", "couchbase-mcp-server"],
      "env": {
        "CB_MCP_READ_ONLY_MODE": "${CB_MCP_READ_ONLY_MODE:-true}",
        "CB_MCP_DISABLED_TOOLS": "${CB_MCP_DISABLED_TOOLS:-}",
        "CB_MCP_CONFIRMATION_REQUIRED_TOOLS": "${CB_MCP_CONFIRMATION_REQUIRED_TOOLS:-}"
      }
    }
  }
}
